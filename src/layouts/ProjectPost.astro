---
export interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  lang: string;
  url?: string;
  repo?: string;
  status: string;
  featured?: boolean;
}

const { title, description, date, tags, lang, url, repo, status, featured } = Astro.props;

import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const formattedDate = date.toLocaleDateString(lang, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const backLabels: Record<string, string> = {
  es: 'Volver a proyectos',
  en: 'Back to projects',
  gl: 'Volver a proxectos',
};

const statusLabels: Record<string, Record<string, string>> = {
  production: { es: 'Producción', en: 'Production', gl: 'Produción' },
  development: { es: 'Desarrollo', en: 'Development', gl: 'Desenvolvemento' },
  concept: { es: 'Concepto', en: 'Concept', gl: 'Concepto' },
};

const statusColors: Record<string, string> = {
  production: '--color-green',
  development: '--color-yellow',
  concept: '--color-orange',
};

const statusLabel = statusLabels[status]?.[lang] || status;
const statusColor = statusColors[status] || '--color-text-muted';
---

<Layout title={`${title} | Projects`} description={description} lang={lang}>
  <Navbar lang={lang} activePage="projects" basePath="projects" />

  <main class="container post-content">
    <a href={`/${lang}/projects`} class="back-link">
      <span class="back-arrow">&lt;-</span> {backLabels[lang] || backLabels.es}
    </a>

    <article class="post terminal-panel">
      <div class="terminal-panel-header">
        <span class="terminal-panel-title">~/projects/{Astro.url.pathname.split('/').pop()}</span>
        <span class="header-status" style={`color: var(${statusColor})`}>{statusLabel}</span>
      </div>

      <div class="terminal-panel-body">
        <header class="post-header">
          <h1 class="post-title">
            {featured && <span class="featured-star">*</span>}
            {title}
          </h1>
          <div class="post-meta">
            <span class="meta-item">
              <span class="meta-label">date:</span> {formattedDate}
            </span>
            <span class="meta-item">
              <span class="meta-label">status:</span>
              <span style={`color: var(${statusColor})`}>{statusLabel}</span>
            </span>
            {url && (
              <span class="meta-item">
                <span class="meta-label">url:</span>
                <a href={url} target="_blank" rel="noreferrer" class="meta-link">{url.replace('https://', '')}</a>
              </span>
            )}
            {repo && (
              <span class="meta-item">
                <span class="meta-label">repo:</span>
                <a href={repo} target="_blank" rel="noreferrer" class="meta-link">{repo.replace('https://github.com/', '')}</a>
              </span>
            )}
          </div>
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </header>

        <div class="post-body prose">
          <slot />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .post-content {
    padding-top: 88px;
    padding-bottom: 3rem;
    max-width: 760px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-cyan); }
  .back-arrow { color: var(--color-accent-prompt); }

  .header-status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    font-size: 1.75rem;
    color: var(--color-green);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .featured-star {
    color: var(--color-yellow);
    margin-right: 0.25rem;
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .meta-item {
    display: flex;
    gap: 0.5rem;
  }

  .meta-label { color: var(--color-purple); }
  .meta-link { color: var(--color-cyan); text-decoration: underline; text-underline-offset: 3px; }
  .meta-link:hover { color: var(--color-green); }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Prose - MDX content styling */
  .prose {
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-size: 0.9375rem;
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--color-cyan);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-purple);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) { margin-bottom: 1rem; }

  .prose :global(a) {
    color: var(--color-cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) { color: var(--color-green); }
  .prose :global(strong) { color: var(--color-text-primary); font-weight: 600; }
  .prose :global(em) { color: var(--color-yellow); font-style: italic; }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }

  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(li::marker) { color: var(--color-accent-prompt); }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-card);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--color-pink);
  }

  .prose :global(pre) {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  /* retro90s: inline code like DOS prompt */
  :global([data-theme="retro90s"]) .prose :global(code:not(pre code)) {
    background: #000000;
    color: #00ff00;
    border-radius: 0;
    font-family: 'Courier New', monospace;
  }

  /* y2k: inline code with web 2.0 style */
  :global([data-theme="y2k"]) .prose :global(code:not(pre code)) {
    background: #e8f0ff;
    color: #0066cc;
    border-radius: 4px;
    border: 1px solid #a8c8f0;
    font-family: 'Courier New', monospace;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-purple);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  @media (max-width: 600px) {
    .post-title { font-size: 1.35rem; }
  }
</style>
