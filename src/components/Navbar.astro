---
import { SUPPORTED_LANGUAGES } from '../utils/data';
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

export interface Props {
  lang: string;
  activePage?: string;
  basePath?: string;
}

const { lang, activePage = 'home', basePath } = Astro.props;

const navLabels: Record<string, Record<string, string>> = {
  es: { home: 'Inicio', experience: 'Experiencia', education: 'Educación', skills: 'Skills', projects: 'Proyectos', blog: 'Blog' },
  en: { home: 'Home', experience: 'Experience', education: 'Education', skills: 'Skills', projects: 'Projects', blog: 'Blog' },
  gl: { home: 'Inicio', experience: 'Experiencia', education: 'Educación', skills: 'Skills', projects: 'Proxectos', blog: 'Blog' },
};

const nav = navLabels[lang] || navLabels.es;

const links = [
  { key: 'home',       href: `/${lang}`,            icon: 'home' },
  { key: 'experience', href: `/${lang}/experience`,  icon: 'briefcase' },
  { key: 'education',  href: `/${lang}/education`,   icon: 'book-open' },
  { key: 'skills',     href: `/${lang}/skills`,      icon: 'terminal' },
  { key: 'projects',   href: `/${lang}/projects`,    icon: 'package' },
  { key: 'blog',       href: `/${lang}/blog`,        icon: 'pen-square' },
];

// For lang-switcher: preserve the current page path when switching lang
const currentPath = basePath || '';
---

<nav class="navbar">
  <div class="nav-content container">
    <a href={`/${lang}`} class="logo">
      <span class="logo-prompt">&gt;</span>
      <span class="logo-text">JRM</span>
      <span class="cursor-blink"></span>
    </a>

    <div class="nav-links">
      {links.map((link) => (
        <a href={link.href} class={`nav-link ${activePage === link.key ? 'active' : ''}`}>
          <Icon name={link.icon} size={13} />
          {nav[link.key]}
        </a>
      ))}
    </div>

    <div class="nav-right">
      <ThemeToggle lang={lang} />

      <div class="lang-switcher">
        {SUPPORTED_LANGUAGES.map((l) => (
          <a
            href={currentPath ? `/${l}/${currentPath}` : `/${l}`}
            class={`lang-btn ${l === lang ? 'active' : ''}`}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </div>

      <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false">
        <span class="hamburger-icon">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" aria-hidden="true">
    <div class="mobile-nav-links">
      {links.map((link) => (
        <a href={link.href} class={`mobile-nav-link ${activePage === link.key ? 'active' : ''}`}>
          <Icon name={link.icon} size={14} />
          {nav[link.key]}
        </a>
      ))}
    </div>
    <div class="mobile-lang-switcher">
      <ThemeToggle lang={lang} />
      {SUPPORTED_LANGUAGES.map((l) => (
        <a
          href={currentPath ? `/${l}/${currentPath}` : `/${l}`}
          class={`lang-btn ${l === lang ? 'active' : ''}`}
        >
          {l.toUpperCase()}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 56px;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .logo:hover { color: var(--color-text-primary); }
  .logo-prompt { color: var(--color-accent-prompt); }
  .logo-text { color: var(--color-green); }

  .nav-links {
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  [data-theme="light"] .nav-link:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .nav-link.active { color: var(--color-cyan); }

  /* Right side group: lang-switcher + theme + hamburger */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-toggle {
    flex-shrink: 0;
  }

  .lang-switcher {
    display: flex;
    gap: 2px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .lang-btn {
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: transparent;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .lang-btn:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  [data-theme="light"] .lang-btn:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .lang-btn.active {
    background: var(--color-border);
    color: var(--color-green);
  }

  /* Hamburger button — hidden on desktop */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
  }

  .menu-toggle:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text-primary);
  }

  .menu-toggle.open {
    border-color: var(--color-cyan);
    color: var(--color-cyan);
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 16px;
  }

  .hamburger-icon span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: currentColor;
    border-radius: 1px;
    transition: all 0.2s ease;
    transform-origin: center;
  }

  /* ✕ animation when open */
  .menu-toggle.open .hamburger-icon span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .menu-toggle.open .hamburger-icon span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-toggle.open .hamburger-icon span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  /* Mobile drawer — hidden by default */
  .mobile-menu {
    display: flex;
    flex-direction: column;
    border-top: 0px solid var(--color-border);
    background: var(--color-bg-surface);
    overflow: hidden;
    max-height: 0;
    visibility: hidden;
    opacity: 0;
    transition: 
      max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1), 
      opacity 0.2s ease-in-out,
      visibility 0.3s,
      border-width 0.1s;
  }

  .mobile-menu.open {
    max-height: 500px;
    visibility: visible;
    opacity: 1;
    border-top-width: 1px;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all var(--transition-fast);
  }

  .mobile-nav-link:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.04);
    border-left-color: var(--color-border);
  }

  [data-theme="light"] .mobile-nav-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .mobile-nav-link.active {
    color: var(--color-cyan);
    border-left-color: var(--color-cyan);
    background: rgba(139, 233, 253, 0.05);
  }

  .mobile-lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .mobile-lang-switcher .theme-toggle {
    flex-shrink: 0;
  }

  .mobile-lang-switcher .lang-btn {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
  }

  .mobile-lang-switcher .lang-btn.active {
    background: var(--color-border);
    color: var(--color-green);
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .lang-switcher {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }

    .mobile-menu {
      display: flex;
    }
  }
</style>

<script>
  function initNavbar() {
    const containers = document.querySelectorAll('.navbar');
    
    containers.forEach(navbar => {
      const toggle = navbar.querySelector('.menu-toggle') as HTMLButtonElement | null;
      const menu = navbar.querySelector('.mobile-menu') as HTMLElement | null;

      if (!toggle || !menu) return;

      const toggleMenu = (force?: boolean) => {
        const willOpen = force !== undefined ? force : !menu.classList.contains('open');
        
        menu.classList.toggle('open', willOpen);
        toggle.classList.toggle('open', willOpen);
        toggle.setAttribute('aria-expanded', String(willOpen));
        menu.setAttribute('aria-hidden', String(!willOpen));
      };

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleMenu();
      });

      // Close drawer when any link inside is clicked
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => toggleMenu(false));
      });

      // Optional: Close when clicking outside
      document.addEventListener('click', (e) => {
        if (menu.classList.contains('open') && !navbar.contains(e.target as Node)) {
          toggleMenu(false);
        }
      });
    });
  }

  // Initialize on load
  initNavbar();

  // Handle Astro page loads if using transitions (optional safety)
  document.addEventListener('astro:page-load', initNavbar);
</script>
