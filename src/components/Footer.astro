---
import Icon from './Icon.astro';

export interface Props {
  text?: string;
}

const { text = 'EOF' } = Astro.props;
---

<footer class="footer">
  <div class="container footer-content">
    <Icon name="terminal" size={13} class="footer-icon" />
    <span class="footer-muted">{text}</span>
  </div>
</footer>

<style>
  .footer {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
  }

  .footer-content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer-icon {
    color: var(--color-accent-prompt);
  }

  .footer-muted {
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
