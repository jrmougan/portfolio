---
import Icon from './Icon.astro';

export interface Props {
  skills: any;
  colors?: any;
}

const { skills } = Astro.props;

// Map categories to Dracula colors
const catColors: Record<string, string> = {
  frontend: 'tag--frontend',
  backend: 'tag--backend',
  tools: 'tag--tools',
  gamedev: 'tag--gamedev',
};

// Map categories to pixelarticons icon names
const catIcons: Record<string, string> = {
  frontend: 'braces',
  backend:  'server',
  tools:    'tool-case',
  gamedev:  'gamepad',
};
---

<div class="skills-section terminal-panel animate-on-load delay-4">
  <div class="terminal-panel-header">
    <span class="terminal-panel-title">~/skills --list</span>
  </div>

  <div class="terminal-panel-body">
    <div class="skills-grid">
      {skills[0].items.map((skill: any) => (
        <span class={`tag ${catColors[skill.cat] || ''}`}>
          {catIcons[skill.cat] && (
            <Icon name={catIcons[skill.cat]} size={11} />
          )}
          {skill.name}
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
</style>
