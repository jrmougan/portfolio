---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  icon?: string;
}

const { title, icon } = Astro.props;
---

<div class="section-header">
  {icon
    ? <Icon name={icon} size={20} class="section-icon" />
    : <span class="section-prompt">&gt;_</span>
  }
  <h2 class="section-title">{title}</h2>
  <div class="section-line"></div>
</div>

<style>
  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .section-prompt {
    font-family: var(--font-pixel);
    font-size: 1.25rem;
    color: var(--color-accent-prompt);
    flex-shrink: 0;
  }

  .section-icon {
    color: var(--color-accent-prompt);
    flex-shrink: 0;
  }

  .section-title {
    font-size: 1.75rem;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .section-line {
    height: 1px;
    flex-grow: 1;
    background: var(--color-border);
  }

  @media (max-width: 600px) {
    .section-title {
      font-size: 1.35rem;
    }
  }
</style>
