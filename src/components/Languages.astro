---
export interface Props {
  items: any;
}

const { items } = Astro.props;

// Cycle through accent colors for each language
const langColors = ['--color-cyan', '--color-purple', '--color-pink', '--color-orange', '--color-yellow'];
---

<div class="languages-section terminal-panel animate-on-load delay-4">
  <div class="terminal-panel-header">
    <span class="terminal-panel-title">~/languages --verbose</span>
  </div>

  <div class="terminal-panel-body">
    <div class="languages-list">
      {items.map((lang: any, i: number) => (
        <div class="language-row">
          <span class="lang-indicator" style={`color: var(${langColors[i % langColors.length]}); border-color: var(${langColors[i % langColors.length]});`}>
            {lang.language}
          </span>
          <span class="lang-separator">---</span>
          <span class="lang-level">{lang.level}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .languages-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .language-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .lang-indicator {
    font-family: var(--font-heading);
    font-size: 1rem;
    white-space: nowrap;
    min-width: 100px;
  }

  .lang-separator {
    color: var(--color-border);
    flex-shrink: 0;
  }

  .lang-level {
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .language-row {
      flex-direction: column;
      gap: 0.25rem;
    }

    .lang-separator {
      display: none;
    }

    .lang-indicator {
      min-width: auto;
    }
  }
</style>
