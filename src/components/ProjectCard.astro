---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  description: string;
  slug: string;
  lang: string;
  tags: string[];
  date: Date;
  url?: string;
  status: string;
  featured?: boolean;
}

const { title, description, slug, lang, tags, date, url, status, featured } = Astro.props;

const statusLabels: Record<string, Record<string, string>> = {
  production: { es: 'Producción', en: 'Production', gl: 'Produción' },
  development: { es: 'Desarrollo', en: 'Development', gl: 'Desenvolvemento' },
  concept: { es: 'Concepto', en: 'Concept', gl: 'Concepto' },
};

const statusColors: Record<string, string> = {
  production: '--color-green',
  development: '--color-yellow',
  concept: '--color-orange',
};

const formattedDate = date.toLocaleDateString(lang, {
  year: 'numeric',
  month: 'short',
});

const statusLabel = statusLabels[status]?.[lang] || status;
const statusColor = statusColors[status] || '--color-text-muted';
---

<a href={`/${lang}/projects/${slug}`} class="project-card terminal-panel animate-on-load">
  <div class="terminal-panel-header">
    <Icon name="git-branch" size={12} class="icon-branch" />
    <span class="terminal-panel-title">~/{slug}</span>
    <span class="header-status" style={`color: var(${statusColor})`}>{statusLabel}</span>
  </div>

  <div class="terminal-panel-body">
    <div class="card-top">
      <h3 class="card-title">
        {featured && <span class="featured-star">*</span>}
        {title}
      </h3>
      <span class="card-date">{formattedDate}</span>
    </div>

    <p class="card-description">{description}</p>

    <div class="card-footer">
      <div class="card-tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      {url && (
        <span class="card-url">
          <Icon name="external-link" size={11} />
          {url.replace('https://', '')}
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .project-card {
    text-decoration: none;
    display: block;
    transition: border-color var(--transition-fast);
    margin-bottom: 1.25rem;
  }

  .project-card:hover {
    border-color: var(--color-border-focus);
  }

  .header-status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--color-green);
  }

  .project-card:hover .card-title {
    color: var(--color-cyan);
  }

  .featured-star {
    color: var(--color-yellow);
    margin-right: 0.25rem;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-description {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-url {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-cyan);
    white-space: nowrap;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .icon-branch {
    color: var(--color-text-muted);
  }

  @media (max-width: 600px) {
    .card-top {
      flex-direction: column;
      gap: 0.25rem;
    }

    .card-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
